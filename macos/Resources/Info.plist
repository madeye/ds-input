<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Standard bundle metadata -->
    <key>CFBundleIdentifier</key>
    <string>io.github.madeye.dsinput</string>

    <key>CFBundleName</key>
    <string>DSInput</string>

    <key>CFBundleDisplayName</key>
    <string>DS Input</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>

    <key>CFBundleExecutable</key>
    <string>DSInput</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <!-- Prevent a Dock icon / menubar appearance; run as a background service -->
    <key>LSUIElement</key>
    <true/>

    <key>LSBackgroundOnly</key>
    <false/>

    <!-- InputMethodKit keys -->

    <!--
        This name must match what you pass to IMKServer(name:...) in AppDelegate.
        macOS routes composition events to the server registered under this name.
    -->
    <key>InputMethodConnectionName</key>
    <string>DSInput_Connection</string>

    <!--
        The Swift class name for the IMKInputController subclass.
        Must be the fully-qualified Swift class name (module prefix for ObjC
        interop is the product module name, which equals the executable name).
    -->
    <key>InputMethodServerControllerClass</key>
    <string>DSInputController</string>

    <!--
        Declare the character repertoires this input method supports, as
        ISO-15924 SCRIPT CODES (not BCP-47 language tags). "Hans" = Simplified
        Han, "Latn" = Latin (the pinyin the user types). Using "zh-Hans" here is
        invalid and prevents the input source from registering.
    -->
    <key>tsInputMethodCharacterRepertoireKey</key>
    <array>
        <string>Hans</string>
        <string>Latn</string>
    </array>

    <!--
        Input mode dictionary. IMK requires the modes under tsInputModeListKey
        (keyed by a unique reverse-DNS mode id) plus tsVisibleInputModeOrdered-
        ArrayKey. The script keys (tsInputModeScriptKey / PrimaryInScriptKey)
        are what file the mode under "Chinese (Simplified)" in the picker —
        modeled on the system's own Chinese input methods.
    -->
    <key>ComponentInputModeDict</key>
    <dict>
        <key>tsInputModeListKey</key>
        <dict>
            <key>io.github.madeye.dsinput.pinyin</key>
            <dict>
                <key>TISInputSourceID</key>
                <string>io.github.madeye.dsinput.pinyin</string>
                <key>tsInputModeScriptKey</key>
                <string>smSimpChinese</string>
                <key>tsInputModePrimaryInScriptKey</key>
                <true/>
                <key>tsInputModeDefaultStateKey</key>
                <true/>
                <key>tsInputModeIsVisibleKey</key>
                <true/>
                <key>tsInputModeKeyEquivalentKey</key>
                <string></string>
                <key>tsInputModeKeyEquivalentModifiersKey</key>
                <integer>0</integer>
                <key>tsInputModeCharacterRepertoireKey</key>
                <array>
                    <string>Hans</string>
                </array>
            </dict>
        </dict>
        <key>tsVisibleInputModeOrderedArrayKey</key>
        <array>
            <string>io.github.madeye.dsinput.pinyin</string>
        </array>
    </dict>

    <!-- Required for input methods placed in ~/Library/Input Methods/ -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
</dict>
</plist>
