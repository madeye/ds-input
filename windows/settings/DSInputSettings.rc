// DSInputSettings.rc — the settings dialog template + icon.
#include "../resource.h"
#include <winres.h>

IDI_DSIME ICON "../dsime.ico"

// A simple, resizable-free modal dialog. Units are dialog units (DLU).
IDD_SETTINGS DIALOGEX 0, 0, 320, 280
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "DS Input Settings"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Base URL:",        -1,            10,  10,  70, 10
    EDITTEXT                            IDC_BASE_URL,  90,   8, 220, 12, ES_AUTOHSCROLL

    LTEXT           "API Key:",         -1,            10,  28,  70, 10
    EDITTEXT                            IDC_API_KEY,   90,  26, 220, 12, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Model:",           -1,            10,  46,  70, 10
    EDITTEXT                            IDC_MODEL,     90,  44, 220, 12, ES_AUTOHSCROLL

    LTEXT           "Temperature:",     -1,            10,  64,  70, 10
    EDITTEXT                            IDC_TEMPERATURE, 90, 62,  60, 12, ES_AUTOHSCROLL

    LTEXT           "Max tokens:",      -1,            10,  82,  70, 10
    EDITTEXT                            IDC_MAX_TOKENS, 90,  80,  60, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Timeout (ms):",    -1,            10, 100,  70, 10
    EDITTEXT                            IDC_TIMEOUT_MS, 90,  98,  60, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "Debounce (ms):",   -1,            10, 118,  70, 10
    EDITTEXT                            IDC_DEBOUNCE_MS, 90, 116,  60, 12, ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "System prompt:",   -1,            10, 136,  90, 10
    EDITTEXT                            IDC_SYSTEM_PROMPT, 10, 148, 300, 80,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL

    LTEXT           "",                 IDC_CONFIG_PATH, 10, 232, 300, 10
    LTEXT           "",                 IDC_STATUS,    10, 244, 220, 10

    DEFPUSHBUTTON   "Save",             IDOK,         200, 258,  50, 14
    PUSHBUTTON      "Cancel",           IDCANCEL,     258, 258,  50, 14
END
