// dsime_tsf.rc — resources for the TSF DLL: just the IME icon.
#include "resource.h"
#include <winres.h>

IDI_DSIME ICON "dsime.ico"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_DLL
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "DS Input"
            VALUE "FileDescription",  "DS Input TSF text service"
            VALUE "FileVersion",      "0.1.0.0"
            VALUE "InternalName",     "dsime_tsf"
            VALUE "OriginalFilename", "dsime_tsf.dll"
            VALUE "ProductName",      "DS Input"
            VALUE "ProductVersion",   "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
