# Rust
/core/target/
**/*.rs.bk

# macOS
.DS_Store
/macos/build/
/macos/*.app/
/macos/*.xcodeproj/
/macos/DerivedData/

# Windows
/windows/build/
/windows/out/
/windows/dist/
/windows/installer/build/
*.obj
*.pdb
*.exp
*.ilk

# Editor
.idea/
.vscode/
*.swp

# macOS installer app build artifacts (generated by build-installer.sh / XcodeGen)
/macos/Installer/build/
/macos/Installer/*.xcodeproj/

# Local code-signing credentials (never commit)
/macos/.signing.env
